# CloudAI — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Django ────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────
# SQLite (default for dev, no config needed)
# For PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/cloudai

# ── Celery / Redis ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Gmail OAuth 2.0 ───────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/
GOOGLE_OAUTH_FRONTEND_REDIRECT=http://localhost:5173/accounts

# ── LLM API (OpenAI-compatible) ───────────────────────────────────
# Used for email classification, summarisation, and digests
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# ── AWS (production only) ─────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_STORAGE_BUCKET_NAME=
